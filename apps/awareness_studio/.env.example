# ── Inputs ──────────────────────────────────────────────────────────────────
# Override default inputs/notion_export/ path
# NOTION_EXPORT_DIR=/absolute/path/to/your/exports

# ── Index backend ────────────────────────────────────────────────────────────
INDEX_BACKEND=bm25          # "bm25" (offline, default) | "embedding"

# ── Embeddings (only needed when INDEX_BACKEND=embedding) ───────────────────
EMBEDDING_PROVIDER=local_stub   # "local_stub" (offline test) | "openai"
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIM=64              # 64 for stub, 1536 for openai ada

# ── LLM provider ─────────────────────────────────────────────────────────────
LLM_PROVIDER=anthropic      # "anthropic" (default) | "openai"
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.7

# ── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── OpenAI ───────────────────────────────────────────────────────────────────
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1
